<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:clickable="true"
    android:focusable="true">

    <!-- Üst Bar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/white"
        android:contentDescription="Kapat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvNowPlaying"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Şu An Çalıyor"
        android:textColor="#8A84BB"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnFullDownload"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/stat_sys_download"
        app:tint="@color/white"
        android:contentDescription="İndir"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Büyük Albüm Kapağı -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvAlbumArt"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="40dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="20dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvNowPlaying">

        <ImageView
            android:id="@+id/ivFullArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Albüm Kapağı"
            tools:src="@tools:sample/avatars" />
    </androidx.cardview.widget.CardView>

    <!-- Şarkı Bilgisi -->
    <TextView
        android:id="@+id/tvFullTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cvAlbumArt"
        tools:text="Şarkı İsmi" />

    <TextView
        android:id="@+id/tvFullArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#8A84BB"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@+id/tvFullTitle"
        app:layout_constraintStart_toStartOf="@+id/tvFullTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvFullTitle"
        tools:text="Sanatçı İsmi" />

    <!-- SeekBar ve Süreler -->
    <SeekBar
        android:id="@+id/fullPlayerSeekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:max="1000"
        android:progressDrawable="@drawable/seekbar_progress"
        android:thumbTint="@color/accent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvFullArtist" />

    <TextView
        android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:text="0:00"
        android:textColor="#8A84BB"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@+id/fullPlayerSeekBar"
        app:layout_constraintTop_toBottomOf="@+id/fullPlayerSeekBar" />

    <TextView
        android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:text="0:00"
        android:textColor="#8A84BB"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@+id/fullPlayerSeekBar"
        app:layout_constraintTop_toBottomOf="@+id/fullPlayerSeekBar" />

    <!-- Kontroller -->
    <LinearLayout
        android:id="@+id/llControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tvCurrentTime">

        <ImageButton
            android:id="@+id/btnShuffle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_share"
            android:contentDescription="Karıştır"
            app:tint="#8A84BB"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/white"
            android:contentDescription="Önceki" />

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_play_button"
            android:padding="16dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/white"
            android:contentDescription="Oynat" />

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            app:tint="@color/white"
            android:contentDescription="Sonraki" />

        <ImageButton
            android:id="@+id/btnRepeat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Tekrarla"
            app:tint="#8A84BB"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Yeni Alt Kontroller: Sıra Çalma ve Karışık Çalma -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/llControls">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSequenceMode"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Sırayla Çal"
            android:textColor="#8A84BB"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconTint="#8A84BB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShuffleMode"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Karışık Çal"
            android:textColor="#8A84BB"
            app:icon="@android:drawable/ic_menu_share"
            app:iconTint="#8A84BB" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
