<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kütüphane"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="İndirilenler"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- MP3 / Video Sekme -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@color/bg_secondary"
        android:orientation="horizontal"
        android:padding="4dp">

        <Button
            android:id="@+id/btnTabMp3"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:backgroundTint="@color/accent"
            android:text="🎵 MP3"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTabVideo"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:backgroundTint="@color/bg_elevated"
            android:text="🎬 Video"
            android:textAllCaps="true"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Çalma Modu Bar -->
    <LinearLayout
        android:id="@+id/playModeBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
            android:id="@+id/btnModeSequential"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/accent"
            android:padding="0dp"
            android:text="Sıralı"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnModeShuffle"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1.2"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/bg_elevated"
            android:padding="0dp"
            android:text="🔀 Karışık"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnPlayAll"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1.5"
            android:backgroundTint="@color/accent_dark"
            android:padding="0dp"
            android:text="▶ Tümünü Çal"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Toplu Seçim Bar (uzun basınca görünür) -->
    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="6dp"
        android:background="@color/bg_elevated"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="2dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSelectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:text="0 seçildi" />

        <Button
            android:id="@+id/btnSelectAll"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:backgroundTint="@color/bg_card"
            android:padding="0dp"
            android:text="Tümü"
            android:textColor="@color/accent"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btnAddToPlaylistSelected"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="@color/accent"
            android:padding="0dp"
            android:text="Ekle"
            android:textColor="@color/white"
            android:textSize="10sp" />

        <Button
            android:id="@+id/btnDeleteSelected"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:backgroundTint="@color/error"
            android:padding="0dp"
            android:text="Sil"
            android:textColor="@color/white"
            android:textSize="10sp" />

        <ImageButton
            android:id="@+id/btnCancelSelection"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/text_secondary" />

    </LinearLayout>

    <!-- Liste -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDownloads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Boş durum -->
    <LinearLayout
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/stat_sys_download_done"
            android:tint="@color/text_hint" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Henüz indirilen müzik yok"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

    </LinearLayout>

</LinearLayout>
